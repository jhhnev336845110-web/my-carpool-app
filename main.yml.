name: Build APK
on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Build with Buildozer
        uses: ArtemSBulat/buildozer-action@v1.6.1
        with:
          buildozer_version: master
          command: android debug

      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: carpool-app
          path: bin/*.apk
